generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  Concert
  Festival
  Exposition
  Theatre
  Conference
  Salon
  Spectacle
}

enum TicketType {
  VIP
  Standard
  EarlyBird
}

model Event {
  id          Int       @id @default(autoincrement())
  image       String
  title       String
  date        DateTime
  time        String
  location    String
  category    Category
  organizator String
  description String
  tickets     Ticket[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Ticket {
  id          Int        @id @default(autoincrement())
  type        TicketType
  price       Float
  quantity    Int
  maxPerUser  Int        @default(2)
  active      Boolean    @default(true)
  eventId     Int
  userId      Int        @default(1)
  event       Event      @relation(fields: [eventId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
